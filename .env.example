# ══════════════════════════════════════
# Growth OS — 环境变量配置
# 复制为 .env.local 并填入真实值
# ══════════════════════════════════════

# ── Supabase ──
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI (Claude API) ──
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx
AI_MODEL=claude-sonnet-4-20250514
AI_RATE_LIMIT_RPM=20

# ── 公司信息 (用于邮件签名、AI提示等) ──
NEXT_PUBLIC_COMPANY_NAME=Qimo Clothing
NEXT_PUBLIC_COMPANY_DOMAIN=eomodm.com
COMPANY_SALES_PERSON=Alex
COMPANY_SALES_EMAIL=sales@qimoclothing.com
COMPANY_REPLY_EMAIL=alex@qimoclothing.com

# ── Google Custom Search (客户搜索，免费100次/天) ──
# 1. https://programmablesearchengine.google.com → 创建搜索引擎 → 获取 Search Engine ID
# 2. https://console.cloud.google.com → 启用 Custom Search API → 获取 API Key
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# ── Proxycurl (LinkedIn深度查询, 可选, $0.01/条) ──
# https://nubela.co/proxycurl → 注册获取 API Key（免费10个信用点试用）
# 仅用于高质量线索的决策者邮箱获取，不配置不影响主流程
PROXYCURL_API_KEY=

# ── Resend (邮件发送) ──
# https://resend.com → API Keys
RESEND_API_KEY=re_xxx

# ── Cron 认证 (必须设置，否则API将拒绝所有请求) ──
CRON_SECRET=your-random-secret

# ── Shopify Webhook ──
SHOPIFY_WEBHOOK_SECRET=

# ── PhantomBuster (社媒采集, 可选) ──
PHANTOMBUSTER_API_KEY=
PHANTOMBUSTER_AGENT_IDS=
PHANTOMBUSTER_WEBHOOK_SECRET=

# ── WhatsApp Business API (可选) ──
# https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ── 系统用户 (自动化任务的 created_by) ──
SYSTEM_USER_ID=
